# ═══════════════════════════════════════════════
# DentalBI 환경변수 설정
# ═══════════════════════════════════════════════
# 이 파일을 .env로 복사하여 사용하세요.
# cp .env.example .env

# ─── 치과 전자차트 MSSQL 연결 정보 ───
MSSQL_HOST=192.168.0.100          # 전자차트 서버 IP
MSSQL_PORT=1433                    # SQL Server 포트
MSSQL_DATABASE=hanaro              # 데이터베이스명 (하나로: hanaro, 덴트웹: dentweb)
MSSQL_USER=dentalbi_reader         # 읽기전용 계정
MSSQL_PASSWORD=your_secure_password

# ─── 전자차트 종류 ───
# hanaro  = 하나로 3.0
# dentweb = 덴트웹
# oneclick = 원클릭
CHART_TYPE=hanaro

# ─── AI 인사이트 (선택) ───
CLAUDE_API_KEY=sk-ant-api03-...    # Anthropic Claude API 키

# ─── PostgreSQL (Docker 자동 설정) ───
DATABASE_URL=postgresql://dentalbi:dentalbi@postgres:5432/dentalbi

# ─── Redis (Docker 자동 설정) ───
REDIS_URL=redis://redis:6379
